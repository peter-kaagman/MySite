<div class='row sidebar-top'>
  <p>Sidebar</p>
</div>

<div class='row sidebar_bottom'>
  <% IF user %>
    <ul class='sidebar_list'>
      <li>Welkom: <% user.userid %></li>
      <li>Je rol is: <% user.role %></li>
      <li><img src="<% user.avatar %>" width="100px"></li>
      <li><a href='/logout'>LogOut</a></li>
    </ul>
  <% ELSE %>
    <p>Er is niemand ingelogd, <a href='/login'>Login</a></p>
  <% END %>
</div>
