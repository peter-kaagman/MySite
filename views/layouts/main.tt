<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="<% settings.charset %>">
  <meta 
    name="viewport" 
    content="width=device-width, initial-scale=1.0, user-scalable=yes"
  >
  <title><% title %></title>
  <% IF meta_description %>
    <meta name="description" content="<% meta_description %>">
  <% END %>

  <% IF canonical_url %>
    <link rel="canonical" href="<% canonical_url %>">
  <% END %>
  
  <link href="/css/vendor/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% IF page == 'article_edit' %>
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css">
  <% END %>

</head>
<body>
  <div class="container">
    <div class='row'>
      <div id='header'><% INCLUDE includes/header.tt %></div>
    </div>
    <div class='row'>
      <% INCLUDE includes/navbar.tt %>
    </div>
    <div class='row'>
      <div class= 'col-sm-8'>
        <div id='content'><% content %></div>
      </div>
      <div id='sidebar' class='col-sm-4'>
        <% INCLUDE includes/sidebar.tt %>
      </div>
    </div>
    <div class='row'>
      <div id='footer'><% INCLUDE includes/footer.tt %></div>
    </div>
  </div>
  <script src="/javascripts/vendor/bootstrap.bundle.min.js"></script>
  <% IF page == 'article_edit' %>
    <script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
    <script src="/javascripts/modules/toast_editor.js"></script>
    <script src="/javascripts/article_edit.js"></script>
  <% END %>
  <% IF show_content %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script type="module" src="/javascripts/content_show.js"></script>
  <% END %>
</body>
</html>
