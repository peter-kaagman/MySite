<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="<% settings.charset %>">
  <meta 
    name="viewport" 
    content="width=device-width, initial-scale=1.0, user-scalable=yes"
  >
  <title><% title %></title>
  <!-- CSRF token for JS -->
  <% IF meta_description %>
    <meta name="description" content="<% meta_description %>">
  <% END %>

  
  <link rel="canonical" href="<% base_url %><% path %>">
  
  <% IF page_type %>
    <% SET seotemplate = "seo/" _ page_type _ ".tt"%>
    <% TRY %>
      <% INCLUDE $seotemplate %>
    <% CATCH file %>
      <!-- Geen seo template gevonden voor page_type: <% page_type %> -->
    <% END %>
  <% END %>

  <link href="/css/vendor/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% IF page == 'article_edit' %>
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css">
  <% END %>

</head>
<body>
  <div class="container">
    <div class="row">
      <div class="col-12">
        <% INCLUDE includes/header.tt %>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <% INCLUDE includes/navbar.tt %>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-md-8">
        <div id="content"><% content %></div>
      </div>
      <div class="col-md-4">
        <% INCLUDE includes/sidebar.tt %>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <% INCLUDE includes/footer.tt %>
      </div>
    </div>
  </div>
  <script src="/javascripts/vendor/bootstrap.bundle.min.js"></script>
  <% IF page == 'article_edit' %>
    <script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
    <script type="module" src="/javascripts/article_edit.js"></script>
  <% END %>
  <% IF show_content %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10.9.0/dist/mermaid.min.js"></script>
    <script type="module" src="/javascripts/content_show.js"></script>
  <% END %>
</body>
</html>
