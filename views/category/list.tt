<% IF list.size %>
  <% IF category.desc %>
    <% render_markdown(category.desc) %>
  <% ELSE %>
    <p>Geen beschrijving beschikbaar.</p>
  <% END %>
  <ul>
    <% FOREACH article IN list %>
      <li>
        <a href="<% base_url %><% article.url %>">
          <% article.title %>
        </a>@<% article.created %><br>
        <p><% render_markdown(article.abstract) %></p>
      </li>
    <% END %>
  </ul>
<% ELSE %>
  <h1>Geen artikelen gevonden in deze categorie.</h1>
<% END %>
