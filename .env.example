# Environment variables voor Docker Compose
# Kopieer naar .env en pas waarden aan

# Session secret (genereer met: openssl rand -base64 32)
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHAR_STRING

# PostgreSQL Database
DB_NAME=mysite
DB_USER=mysite_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis Session Store
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Application
DANCER_ENVIRONMENT=production
LOG_LEVEL=info
